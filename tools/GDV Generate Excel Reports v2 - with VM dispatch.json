    {
      "parameters": {
        "jsCode": "const results = [];\n\nfor (const item of $input.all()) {\n  const products = item.json.products || [];\n\n  for (const p of products) {\n    const cat = (p.product_category || '').toLowerCase();\n    if (!cat.includes('apple retail')) continue;\n\n    const qty = (p.location_quantities || []).reduce((sum, lq) => sum + (parseInt(lq.quantity) || 0), 0);\n    if (qty <= 0) continue;\n\n    let sku = (p.name || '').trim();\n    if (sku.startsWith('Z') && sku.length > 4) sku = sku.substring(0, 4);\n\n    results.push({\n      json: {\n        'Inventory Location ID': '745667',\n        'Apple Marketing Part number': sku,\n        'UPC code': '',\n        'JAN Code': '',\n        'Inventory Free Quantity': qty,\n        'Inventory Demo Quantity': '',\n        'Inventory Internal In-transit Quantity': '',\n        'Inventory Non-Sellable Quantity': '',\n        'Inventory Reserved Quantity': '',\n        'Inventory Back Order Quantity': '',\n        'Inventory Received Quantity': '',\n        'Errors': ''\n      }\n    });\n  }\n}\n\nreturn results;"
      },
