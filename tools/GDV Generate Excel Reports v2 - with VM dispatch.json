        "jsCode": "const items = $input.all().map(i => i.json);\nreturn items.map(item => ({\n  json: {\n    'Sales Location ID': item['Location'] || '',\n    'Apple Marketing Part number': item['Apple Product #'] || '',\n    'UPC Code': '',\n    'JAN Code': '',\n    'Sell Through Sold Quantity': item['Sold Qty'] || 0,\n    'Sell Through Returned Quantity': item['Returned Qty'] || 0,\n    'Serial Numbers': '',\n    'Unit Selling Price': '',\n    'Invoice No': item['Invoice #'] || '',\n    'Invoice Line Item No': '',\n    'Invoice Date': item['Invoice Date'] || '',\n    'End Customer ID': '',\n    'End Customer Name': item['EU Company'] || '',\n    'End Customer Address': item['EU Address'] || '',\n    'End Customer City': item['EU City'] || '',\n    'End Customer Province State': '',\n    'End Customer Postal Zip code': '',\n    'End Customer Country or Region': item['Country'] || '',\n    'End Customer Type': item['Type'] || 'EN',\n    'Errors': ''\n  }\n}));"
      },
